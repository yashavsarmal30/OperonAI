# Openron B2A Engine MVP Configuration

# --- Model Selection (Local or API) ---
# Format: litellm supported strings (e.g., 'openai/gpt-4o', 'ollama/llama3', 'anthropic/claude-3-opus')
PLANNER_MODEL=ollama/gpt-oss
AUTOMATION_MODEL=openai/gpt-4o
RESPONSE_MODEL=ollama/gpt-oss

# --- Stagehand (Browser Automation) Configuration ---
# The provider for Stagehand (e.g., openai, anthropic)
STAGEHAND_PROVIDER=openai
# The model for Stagehand to use
STAGEHAND_MODEL=gpt-4o
# The API key for Stagehand's model provider (defaults to OPENAI_API_KEY if using openai)
STAGEHAND_API_KEY=

# --- Provider API Keys ---
# If using API-based models, provide the keys here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_API_KEY=
